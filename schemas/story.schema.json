{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guided-review.dev/schemas/story-v1.json",
  "title": "Guided Review Story v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "snapshotId", "authorship", "title", "kicker", "headline", "introduction", "flow", "hotspots", "stages", "decisions"],
  "properties": {
    "schemaVersion": {"const": 1},
    "snapshotId": {"type": "string", "minLength": 1},
    "authorship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "agent"],
      "properties": {
        "mode": {"enum": ["originating", "reconstructed"]},
        "agent": {"type": "string", "minLength": 1},
        "disclosure": {"type": "string", "minLength": 1}
      }
    },
    "title": {"type": "string", "minLength": 1},
    "kicker": {"type": "string", "minLength": 1},
    "headline": {"type": "string", "minLength": 1},
    "introduction": {"type": "string", "minLength": 1},
    "flow": {"type": "array", "items": {"$ref": "#/$defs/flow"}},
    "hotspots": {"type": "array", "items": {"$ref": "#/$defs/callout"}},
    "stages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/stage"}},
    "decisions": {"type": "array", "items": {"$ref": "#/$defs/decision"}}
  },
  "$defs": {
    "paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "optionalPaths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "detail"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1},
        "evidence": {"$ref": "#/$defs/optionalPaths"}
      }
    },
    "callout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone", "label", "text", "evidence"],
      "properties": {
        "tone": {"enum": ["good", "attention", "risk", "question"]},
        "label": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1},
        "evidence": {"$ref": "#/$defs/paths"}
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "eyebrow", "title", "summary", "reviewLens", "callouts", "files"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "eyebrow": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "reviewLens": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "callouts": {"type": "array", "items": {"$ref": "#/$defs/callout"}},
        "files": {"$ref": "#/$defs/paths"}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "question"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "question": {"type": "string", "minLength": 1},
        "evidence": {"$ref": "#/$defs/optionalPaths"}
      }
    }
  }
}
